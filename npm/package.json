{
  "name": "@josunlp/checkai",
  "version": "0.5.1",
  "packageManager": "bun@1.3.10",
  "description": "CheckAI chess engine — FIDE 2023 rules, move generation, evaluation, search, game management, and export via WebAssembly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JosunLP/checkai.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "chess",
    "engine",
    "wasm",
    "webassembly",
    "ai",
    "fide",
    "analysis"
  ],
  "bin": {
    "checkai": "./bin/checkai.mjs"
  },
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./raw": "./pkg/checkai.js",
    "./wasm": "./pkg/checkai_bg.wasm",
    "./package.json": "./package.json"
  },
  "type": "module",
  "files": [
    "bin/",
    "src/",
    "pkg/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:wasm": "cd ../wasm && wasm-pack build --target nodejs --out-dir ../npm/pkg --out-name checkai",
    "build": "bun run build:wasm && bun ./scripts/prepare-pkg.mjs",
    "verify:pkg": "bun ./scripts/prepare-pkg.mjs",
    "prepack": "bun run build && bun run verify:pkg",
    "prepublishOnly": "bun run verify:pkg"
  }
}
